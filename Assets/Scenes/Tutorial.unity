--- !u!114 &2118983618
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2118983615}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9c2ac4b16ead097439505e335c02793d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogueText: {fileID: 804931888}
  speakerNameText: {fileID: 1045747880}
  character1Image: {fileID: 1393048455}
  character2Image: {fileID: 172478021}
  backButton: {fileID: 14456948}
  dialogues:
  - speakerName: "\u0410\u043B\u0438\u0441\u0430"
    sentence: "\u041F\u0440\u0438\u0432\u0435\u0442! \u0414\u0430\u0432\u0430\u0439
      \u043D\u0430\u0443\u0447\u0438\u043C\u0441\u044F \u0443\u043C\u043D\u043E\u0436\u0430\u0442\u044C.
      \u0423\u043C\u043D\u043E\u0436\u0435\u043D\u0438\u0435 - \u044D\u0442\u043E
      \u0431\u044B\u0441\u0442\u0440\u044B\u0439 \u0441\u043F\u043E\u0441\u043E\u0431
      \u0441\u043B\u043E\u0436\u0435\u043D\u0438\u044F \u043E\u0434\u0438\u043D\u0430\u043A\u043E\u0432\u044B\u0445
      \u0447\u0438\u0441\u0435\u043B."
    isCharacter1Speaking: 1
  - speakerName: "\u041F\u0435\u0442\u044F"
    sentence: "\u0417\u0434\u043E\u0440\u043E\u0432\u043E! \u0410 \u043A\u0430\u043A
      \u044D\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442?"
    isCharacter1Speaking: 0
  - speakerName: "\u0410\u043B\u0438\u0441\u0430"
    sentence: "\u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, 3 \xD7 4 \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442,
      \u0447\u0442\u043E \u043C\u044B \u0431\u0435\u0440\u0435\u043C \u0447\u0438\u0441\u043B\u043E
      3 \u0447\u0435\u0442\u044B\u0440\u0435 \u0440\u0430\u0437\u0430: 3 + 3 + 3
      + 3 = 12"
    isCharacter1Speaking: 1
  - speakerName: "\u041F\u0435\u0442\u044F"
    sentence: "\u041F\u043E\u043D\u044F\u0442\u043D\u043E! \u0422\u043E \u0435\u0441\u0442\u044C
      5 \xD7 2 \u0431\u0443\u0434\u0435\u0442 5 + 5 = 10?"
    isCharacter1Speaking: 0
  - speakerName: "\u0410\u043B\u0438\u0441\u0430"
    sentence: "\u0412\u0435\u0440\u043D\u043E! \u0410 \u0432 \u0438\u0433\u0440\u0435
      \u0442\u044B \u0431\u0443\u0434\u0435\u0448\u044C \u0432\u0438\u0434\u0435\u0442\u044C
      \u043F\u0440\u0438\u043C\u0435\u0440\u044B \u0438 \u0432\u044B\u0431\u0438\u0440\u0430\u0442\u044C
      \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439 \u043E\u0442\u0432\u0435\u0442
      \u0438\u0437 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u0438\u0445 \u0432\u0430\u0440\u0438\u0430\u043D\u0442\u043E\u0432."
    isCharacter1Speaking: 1
  - speakerName: "\u041F\u0435\u0442\u044F"
    sentence: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E! \u042F \u0433\u043E\u0442\u043E\u0432
